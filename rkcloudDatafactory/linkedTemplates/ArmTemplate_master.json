{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "rkcloudDatafactory"
		},
		"AzureDataLakeStorage1_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'AzureDataLakeStorage1'"
		},
		"IRsqlselfhostedonpremisis_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'IRsqlselfhostedonpremisis'"
		},
		"LS_AZURE_SQL_DATABASE_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'LS_AZURE_SQL_DATABASE'"
		},
		"AzureDataLakeStorage1_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://sarmastorage.dfs.core.windows.net/"
		},
		"IRsqlselfhostedonpremisis_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "DESKTOP-EVU41JE"
		},
		"IRsqlselfhostedonpremisis_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "AdventureWorks2022"
		},
		"IRsqlselfhostedonpremisis_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "yamini"
		},
		"LS_AZURE_SQL_DATABASE_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "rk.database.windows.net"
		},
		"LS_AZURE_SQL_DATABASE_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "rkcloudDb"
		},
		"LS_AZURE_SQL_DATABASE_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "rama"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "rkcloudDatafactory_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"AzureDataLakeStorage1_accountKey": {
						"value": "[parameters('AzureDataLakeStorage1_accountKey')]"
					},
					"LS_AZURE_SQL_DATABASE_password": {
						"value": "[parameters('LS_AZURE_SQL_DATABASE_password')]"
					},
					"IRsqlselfhostedonpremisis_password": {
						"value": "[parameters('IRsqlselfhostedonpremisis_password')]"
					},
					"AzureDataLakeStorage1_properties_typeProperties_url": {
						"value": "[parameters('AzureDataLakeStorage1_properties_typeProperties_url')]"
					},
					"LS_AZURE_SQL_DATABASE_properties_typeProperties_server": {
						"value": "[parameters('LS_AZURE_SQL_DATABASE_properties_typeProperties_server')]"
					},
					"LS_AZURE_SQL_DATABASE_properties_typeProperties_database": {
						"value": "[parameters('LS_AZURE_SQL_DATABASE_properties_typeProperties_database')]"
					},
					"LS_AZURE_SQL_DATABASE_properties_typeProperties_userName": {
						"value": "[parameters('LS_AZURE_SQL_DATABASE_properties_typeProperties_userName')]"
					},
					"IRsqlselfhostedonpremisis_properties_typeProperties_server": {
						"value": "[parameters('IRsqlselfhostedonpremisis_properties_typeProperties_server')]"
					},
					"IRsqlselfhostedonpremisis_properties_typeProperties_database": {
						"value": "[parameters('IRsqlselfhostedonpremisis_properties_typeProperties_database')]"
					},
					"IRsqlselfhostedonpremisis_properties_typeProperties_userName": {
						"value": "[parameters('IRsqlselfhostedonpremisis_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		},
		{
			"name": "rkcloudDatafactory_ArmTemplate_1",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_1.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					}
				}
			},
			"dependsOn": [
				"[resourceId('Microsoft.Resources/deployments', 'rkcloudDatafactory_ArmTemplate_0')]"
			]
		}
	]
}