{
	"name": "DS_TARGET_DATASET",
	"properties": {
		"linkedServiceName": {
			"referenceName": "AzureDataLakeStorage1",
			"type": "LinkedServiceReference"
		},
		"parameters": {
			"filename": {
				"type": "string"
			},
			"flodername": {
				"type": "string"
			}
		},
		"folder": {
			"name": "Practice"
		},
		"annotations": [],
		"type": "Binary",
		"typeProperties": {
			"location": {
				"type": "AzureBlobFSLocation",
				"fileName": {
					"value": "@dataset().filename",
					"type": "Expression"
				},
				"folderPath": {
					"value": "@concat('Processed/', dataset().flodername)",
					"type": "Expression"
				},
				"fileSystem": "rk-container"
			}
		}
	}
}